# ============================================================
# Social Vision Agents - Configuration
# Copy this file to .env and fill in the values
# ============================================================

# ── Primary LLM (Ollama / Llama 4 local) ─────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama4

# ── Fallback LLM (Groq) ──────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_FALLBACK_MODEL=llama-4-scout-17b-16e-instruct

# ── Google Gemini (optional third LLM provider) ──────────────
# GOOGLE_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_MODEL=gemini-3-pro

# ── Image generation (Grok Imagine — optional, images are manual by default)
GROK_IMAGINE_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROK_IMAGINE_ENABLED=false

# ── Web search (Tavily primary, DuckDuckGo fallback) ─────────
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PostgreSQL (checkpoints + post storage) ──────────────────
DATABASE_URL=postgresql://svagent:changeme_in_production@localhost:5432/social_vision

# ── Observability (LangSmith — free tier) ────────────────────
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=social-vision-agents-prod
LANGSMITH_TRACING=true

# ── Human approval ───────────────────────────────────────────
HUMAN_APPROVAL_REQUIRED=true
APPROVAL_METHOD=file
# APPROVAL_METHOD=slack
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Posting APIs (enable progressively) ──────────────────────
# LINKEDIN_ACCESS_TOKEN=
# X_BEARER_TOKEN=
# X_API_KEY=
# X_API_SECRET=
# TIKTOK_ACCESS_TOKEN=
# META_ACCESS_TOKEN=
